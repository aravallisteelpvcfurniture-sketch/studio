
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores extended information about the user.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL to the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["displayName", "email"]
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "Details of a customer consultation or service request.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who made the request (optional if guest)."
        },
        "name": {
          "type": "string",
          "description": "Customer name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Customer email."
        },
        "phone": {
          "type": "string",
          "description": "Customer contact number."
        },
        "serviceType": {
          "type": "string",
          "enum": ["Kitchen", "Wardrobe", "Wall Paneling", "Full Interior"],
          "description": "Type of service required."
        },
        "message": {
          "type": "string",
          "description": "Additional details or requirements."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "contacted", "closed"],
          "description": "Current status of the request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when requested."
        }
      },
      "required": ["name", "email", "phone", "serviceType"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile document."
    },
    "/serviceRequests/{requestId}": {
      "schema": "#/backend/entities/ServiceRequest",
      "description": "Collection of customer service requests and consultation bookings."
    }
  }
}
