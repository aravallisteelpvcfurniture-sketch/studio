
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the platform.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "shippingAddress": { "type": "string" },
        "billingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents an items available in the shop.",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stockQuantity": { "type": "integer" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stockQuantity"]
    },
    "Cart": {
      "title": "Cart",
      "type": "object",
      "description": "Represents a user's shopping cart.",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a completed purchase.",
      "properties": {
        "userId": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "billingAddress": { "type": "string" }
      },
      "required": ["userId", "totalAmount", "status"]
    },
    "QuoteRequest": {
      "title": "Quote Request",
      "type": "object",
      "description": "A consultation or quote request from a customer.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "serviceType": { "type": "string" },
        "message": { "type": "string" },
        "customerUid": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "customerUid"]
    }
  },
  "auth": {
    "providers": ["google", "password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles stored by UID."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Publicly viewable products."
        }
      },
      {
        "path": "/carts/{userId}/items/{productId}",
        "definition": {
          "entityName": "CartItem",
          "schema": { "type": "object", "properties": { "quantity": { "type": "integer" } } },
          "description": "Items in a user's cart."
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": { "$ref": "#/backend/entities/Order" },
          "description": "Customer orders."
        }
      },
      {
        "path": "/quoteRequests/{requestId}",
        "definition": {
          "entityName": "QuoteRequest",
          "schema": { "$ref": "#/backend/entities/QuoteRequest" },
          "description": "Customer inquiries and consultation requests."
        }
      }
    ]
  }
}
