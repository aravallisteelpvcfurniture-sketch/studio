
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Direct Admin check using UID and Email
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com" || 
        request.auth.uid == "Qmcch2NXxmg47Zf28Wh0KTp9Njt1"
      );
    }

    match /quoteRequests/{requestId} {
      // Anyone can create an inquiry
      allow create: if true;
      // Only Admin can see/list inquiries
      allow read, list: if isAdmin();
      // Admin can update or delete
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
