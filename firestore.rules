/**
 * Firestore Security Rules for Aravalli Steel.
 * Version: 4.0 - Direct Admin Whitelisting
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the primary administrator.
     * Verified via both Email and UID for maximum reliability.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com" ||
        request.auth.uid == "Qmcch2NXxmg47Zf28Wh0KTp9Njt1"
      );
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId) || isStaff();
      allow create, update: if (request.auth != null && request.auth.uid == userId);
    }

    match /products/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId);
    }

    /**
     * @description Customer quote requests.
     * Admin/Staff can list and manage all.
     * Anyone can create an inquiry.
     */
    match /quoteRequests/{requestId} {
      // Allow Admin to see all, allow users to see their own
      allow list: if isAdmin(); 
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /roles_staff/{staffUid} {
      allow get: if (request.auth != null && request.auth.uid == staffUid);
      allow list: if isStaff();
      allow create, update, delete: if false;
    }
    
    // Default catch-all
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}