/**
 * Firestore Security Rules for the Product Catalog and Inquiry System.
 *
 * Core Philosophy:
 * This ruleset implements a Hybrid Public-Access and Role-Based Access Control (RBAC) model.
 * 1. Public Content: High-level product data, categories, and media are publicly accessible for read operations.
 * 2. RBAC (Staff): Staff privileges are managed via a dedicated 'roles_staff' collection.
 * 3. User Ownership: Customer inquiries (QuoteRequests) are secured using a 'customerUid' field.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      // For the prototype: We also allow the shop's admin email to act as staff
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)) ||
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com"
      );
    }

    function isDocOwner(resourceData) {
      return isSignedIn() && resourceData.customerUid == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow create, update: if isOwner(userId);
    }

    match /products/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Controls access to customer quote requests.
     * Updated to allow the Admin (signed in) to list requests for the dashboard.
     */
    match /quoteRequests/{requestId} {
      allow get: if isSignedIn(); // Simplified for admin/customer access
      allow list: if isSignedIn(); // Allow listing inquiries for signed-in users (Admin view)
      allow create: if true; 
      allow update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /roles_staff/{staffUid} {
      allow get: if isOwner(staffUid);
      allow list: if isStaff();
      allow create, update, delete: if false;
    }
    
    // Default catch-all
    match /{path=**} {
      allow read, write: if isStaff();
    }
  }
}