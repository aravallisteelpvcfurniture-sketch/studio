/**
 * Firestore Security Rules for Aravalli Steel.
 * Updated: Forces redeploy to fix listing permissions for Admin.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      // Direct email check for the shop owner/admin
      return isSignedIn() && (
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com" ||
        exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow create, update: if isOwner(userId);
    }

    match /products/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Customer quote requests.
     * Staff/Admin can list and manage all.
     * Customers can only see their own (via customerUid).
     */
    match /quoteRequests/{requestId} {
      allow list: if isStaff(); 
      allow get: if isStaff() || (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow create: if true; // Allow anyone to submit an inquiry
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /roles_staff/{staffUid} {
      allow get: if isOwner(staffUid);
      allow list: if isStaff();
      allow create, update, delete: if false;
    }
    
    // Default catch-all
    match /{path=**} {
      allow read, write: if isStaff();
    }
  }
}