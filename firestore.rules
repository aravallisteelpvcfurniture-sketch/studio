/**
 * Firestore Security Rules for Aravalli Steel.
 * Updated: Forces redeploy and simplifies admin email check for listing.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "aravallisteelpvcfurniture@gmail.com";
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId) || isStaff();
      allow create, update: if (request.auth != null && request.auth.uid == userId);
    }

    match /products/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId);
    }

    /**
     * @description Customer quote requests.
     * Admin/Staff can list and manage all.
     * Customers can only see their own (via customerUid).
     */
    match /quoteRequests/{requestId} {
      // Explicitly allow list if the email matches exactly
      allow list: if isAdmin(); 
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow create: if true; // Allow anyone to submit an inquiry
      allow update, delete: if isAdmin();
    }

    match /roles_staff/{staffUid} {
      allow get: if (request.auth != null && request.auth.uid == staffUid);
      allow list: if isStaff();
      allow create, update, delete: if false;
    }
    
    // Default catch-all
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}