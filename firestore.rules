/**
 * Firestore Security Rules for the Product Catalog and Inquiry System.
 *
 * Core Philosophy:
 * This ruleset implements a Hybrid Public-Access and Role-Based Access Control (RBAC) model.
 * 1. Public Content: High-level product data, categories, and media are publicly accessible for read operations to ensure 
 *    seamless browsing and SEO.
 * 2. RBAC (Staff): Staff privileges are managed via a dedicated 'roles_staff' collection. The mere existence of a 
 *    document in this collection matching a user's UID grants administrative access to manage product data and inquiries.
 * 3. User Ownership: Customer inquiries (QuoteRequests) are secured using a denormalized 'customerUid' field, 
 *    ensuring customers can only access their own submissions while staff maintain a global view.
 *
 * Data Structure:
 * - Root-level collections for Categories, Products, Materials, Colors, VirtualTours, Dealers, GalleryImages, and HeroSliderItems.
 * - 'quoteRequests' for customer inquiries.
 * - 'roles_staff' as a lookup for staff authorization.
 *
 * Key Security Decisions:
 * - Denormalization for Authorization: To optimize performance and reduce database reads, 'customerUid' is 
 *   stored directly on 'quoteRequests' documents.
 * - Structural Segregation: Administrative roles are separated from functional data to prevent privilege escalation.
 * - Schema-Agile Prototyping: While access control is strictly enforced based on UIDs, specific field types are not 
 *   enforced to allow for rapid UI/UX iteration.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated with Firebase Auth.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if a document exists for the current user in the roles_staff collection.
     */
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid));
    }

    /**
     * @description Checks ownership of a resource based on a stored UID field.
     */
    function isDocOwner(resourceData) {
      return isSignedIn() && resourceData.customerUid == request.auth.uid;
    }

    /**
     * @description Verifies a document exists before allowing modification or deletion.
     */
    function isExistingOwner(resourceData) {
      return resource != null && (isDocOwner(resourceData) || isStaff());
    }

    // --- Collection Rules ---

    /**
     * @description Publicly readable catalog and configuration data. Only staff can modify.
     * @path /categories/{categoryId}, /products/{productId}, /materials/{materialId}, /colors/{colorId}, /virtualTours/{virtualTourId}, /dealers/{dealerId}, /galleryImages/{imageId}, /heroSliderItems/{sliderItemId}
     * @allow Public (get, list), Staff (create, update, delete)
     * @deny Non-staff (write)
     * @principle Public read-only for catalog data; RBAC for management.
     */
    match /categories/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /products/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /materials/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /colors/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /virtualTours/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /dealers/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /galleryImages/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }
    match /heroSliderItems/{id} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    /**
     * @description Controls access to customer quote requests.
     * @path /quoteRequests/{quoteRequestId}
     * @allow Owner/Staff (get, list, update, delete), Public (create)
     * @deny Unauthorized users (get, list, write)
     * @principle Denormalized ownership (customerUid) for secure, scalable access control.
     */
    match /quoteRequests/{requestId} {
      allow get: if isDocOwner(resource.data) || isStaff();
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 100); 
      // Note: Clients should filter list queries by customerUid for their own requests.
      
      allow create: if true; // Allows anonymous and signed-in inquiries.
      allow update: if isExistingOwner(resource.data) && (request.resource.data.customerUid == resource.data.customerUid);
      allow delete: if isStaff(); // Usually, inquiries are archived/completed rather than deleted by users.
    }

    /**
     * @description Look-up collection for staff role assignments.
     * @path /roles_staff/{staffUid}
     * @allow Owner (get), Internal/Admin (write)
     * @deny Public (read, write)
     * @principle DBAC (Database Access Control) using document existence as a role flag.
     */
    match /roles_staff/{staffUid} {
      allow get: if isOwner(staffUid);
      allow list: if isStaff();
      allow create, update, delete: if false; // Managed via Firebase Console or Admin SDK only.
    }

  }
}