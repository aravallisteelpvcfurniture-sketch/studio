
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Direct and robust Admin check for both email and UID
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com" || 
        request.auth.uid == "Qmcch2NXxmg47Zf28Wh0KTp9Njt1"
      );
    }

    match /quoteRequests/{requestId} {
      // Anyone can create an inquiry
      allow create: if true;
      // Admin has full control, others cannot read
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // Users can manage their own profile, Admin can see all
      allow get, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // List all users only for Admin
      allow list: if isAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
