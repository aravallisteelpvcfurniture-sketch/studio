
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /quoteRequests/{requestId} {
      allow create: if true;
      allow read: if isSignedIn() && (request.auth.token.email == "aravallisteelpvcfurniture@gmail.com" || request.auth.uid == "Qmcch2NXxmg47Zf28Wh0KTp9Njt1");
    }

    match /users/{userId} {
      allow get, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /products/{id} {
      allow read: if true;
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
