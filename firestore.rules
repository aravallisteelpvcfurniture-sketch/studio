/**
 * Firestore Security Rules for Aravalli Steel.
 * Optimized for Instant Admin Access.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Simplified Admin Check: Primary check via UID for speed and reliability
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "Qmcch2NXxmg47Zf28Wh0KTp9Njt1" ||
        request.auth.token.email == "aravallisteelpvcfurniture@gmail.com"
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create, update: if (isSignedIn() && request.auth.uid == userId);
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{userId}/items/{productId} {
      allow read, write: if (isSignedIn() && request.auth.uid == userId);
    }

    match /quoteRequests/{requestId} {
      // Anyone can create an inquiry
      allow create: if true; 
      // Only Admin can list all or get specific (plus the owner can get)
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Catch-all for Admin: Ultimate safety net
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}